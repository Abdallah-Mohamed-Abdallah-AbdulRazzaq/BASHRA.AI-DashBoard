{
  "info": {
    "name": "Admin Batch 2 - User Management + Patient Profiles",
    "description": "Postman collection for Bashra AI backend admin user management and patient profile admin APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3006"
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "super_admin_token",
      "value": ""
    },
    {
      "key": "doctor_token",
      "value": ""
    },
    {
      "key": "assistant_token",
      "value": ""
    },
    {
      "key": "user_token",
      "value": ""
    },
    {
      "key": "test_user_id",
      "value": "1"
    },
    {
      "key": "test_user_uuid",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Admin User Management",
      "item": [
        {
          "name": "Get User Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/stats",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                "stats"
              ]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users?page=1&limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Search Users By Query",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/search?query=abdallah&page=1&limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                "search"
              ],
              "query": [
                {
                  "key": "query",
                  "value": "abdallah"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Users By Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/status/active?page=1&limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                "status",
                "active"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get User Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/{{test_user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                "{{test_user_id}}"
              ]
            }
          }
        },
        {
          "name": "Get User Medical Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "ar"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/{{test_user_id}}/medical",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                "{{test_user_id}}",
                "medical"
              ]
            }
          }
        },
        {
          "name": "Get User Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users/{{test_user_id}}/logs?page=1&limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                "{{test_user_id}}",
                "logs"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Update User Status - Super Admin",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{super_admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\",\n  \"reason\": \"Testing status update from admin API\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/users/{{test_user_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                "{{test_user_id}}",
                "status"
              ]
            }
          }
        },
        {
          "name": "Update User Status Rollback - Super Admin",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{super_admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\",\n  \"reason\": \"Rollback status after admin API test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/users/{{test_user_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                "{{test_user_id}}",
                "status"
              ]
            }
          }
        },
        {
          "name": "Negative - Normal User Cannot Get Admin Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "users"
              ]
            }
          }
        }
      ]
    },
