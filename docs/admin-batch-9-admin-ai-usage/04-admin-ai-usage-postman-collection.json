{
  "info": {
    "name": "Batch 9 - Admin AI Usage",
    "description": "Postman collection for Admin AI Usage overview, user usage, and policy management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3006"
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "super_admin_token",
      "value": ""
    },
    {
      "key": "user_token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": "1"
    },
    {
      "key": "package_id",
      "value": ""
    },
    {
      "key": "policy_id",
      "value": ""
    },
    {
      "key": "period_key",
      "value": "2026-06"
    }
  ],
  "item": [
    {
      "name": "Overview",
      "item": [
        {
          "name": "Overview - Current Period",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/ai-usage/overview?period_key={{period_key}}"
            }
          }
        },
        {
          "name": "Overview - No Period",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/ai-usage/overview"
            }
          }
        },
        {
          "name": "Negative Overview Invalid Period",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/ai-usage/overview?period_key=2026/06"
            }
          }
        }
      ]
    },
    {
