                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/ai-usage/policies/{{policy_id}}/status"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": true\n}"
            }
          }
        }
      ]
