                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/ai-usage/policies"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policy_name\": \"Batch 9 User AI Usage\",\n  \"scope_type\": \"user\",\n  \"user_id\": \"{{user_id}}\",\n  \"max_total_requests_per_month\": 120,\n  \"max_chat_messages_per_month\": 80,\n  \"max_image_analyses_per_month\": 40,\n  \"max_document_analyses_per_month\": 15,\n  \"max_files_per_session\": 10,\n  \"max_tokens_per_request\": 8000,\n  \"is_active\": true,\n  \"priority\": 5\n}"
            }
          }
        },
