            "body": {
              "mode": "raw",
              "raw": "{\n  \"max_total_requests_per_month\": 150,\n  \"max_chat_messages_per_month\": 100,\n  \"max_image_analyses_per_month\": 50,\n  \"priority\": 3\n}"
            }
          }
        },
        {
          "name": "Deactivate Policy",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{super_admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/ai-usage/policies/{{policy_id}}/status"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false\n}"
            }
          }
        },
        {
          "name": "Reactivate Policy",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{super_admin_token}}"
              },
