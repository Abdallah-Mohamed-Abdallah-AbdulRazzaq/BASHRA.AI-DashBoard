          "name": "Create User Policy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{super_admin_token}}"
              },
