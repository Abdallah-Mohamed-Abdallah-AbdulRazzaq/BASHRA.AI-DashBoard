            ],
            "url": {
              "raw": "{{base_url}}/api/admin/ai-usage/policies"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policy_name\": \"Batch 9 Package AI Usage\",\n  \"scope_type\": \"package\",\n  \"package_id\": \"{{package_id}}\",\n  \"max_total_requests_per_month\": 200,\n  \"max_chat_messages_per_month\": 150,\n  \"max_image_analyses_per_month\": 60,\n  \"max_document_analyses_per_month\": 30,\n  \"max_files_per_session\": 15,\n  \"max_tokens_per_request\": 12000,\n  \"is_active\": true,\n  \"priority\": 20\n}"
            }
          }
        },
        {
          "name": "Update Policy",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept-Language",
                "value": "ar"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{super_admin_token}}"
              },
              {
                "key": "Content-Type",
