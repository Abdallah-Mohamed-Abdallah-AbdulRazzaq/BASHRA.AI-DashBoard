              "mode": "raw",
              "raw": "{\n  \"entity_id\": \"{{target_admin_id}}\",\n  \"entity_type\": \"admin\",\n  \"reason\": \"Unblocking test admin\"\n}"
            }
          }
        }
      ]
    },
